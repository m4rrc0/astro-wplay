---
import { IO, Img, ImgDirectus } from '@components'
import Ad from '@components/ads/Ad.astro'
import placeholderWPlayCircleBlue from '@images/WannaPlay-button-circle-blue.png'
import { getEvents } from '../store/dataService.js'
import { start as startDirectus } from '../services/directus.js'
import { imageDirectusSrc } from '@utils'

// Props passed from the MDX page
const { eventTypeFilter, areaCode, lang = { code: 'fr' }, events } = Astro.props

// Start Directus (login/refresh) before using data
await startDirectus()

const now = new Date()
const in10Days = new Date(now)
in10Days.setDate(in10Days.getDate() + 10)

// Fetch all events (from Directus or cache); async so use await; result stored in allEvents
const allEvents =
  events ??
  (await getEvents({
    // Filter out past events; only include events with start date from now
    after: now,
    // Only events within the next 10 days
    before: in10Days,
  }))

// Holds filtered events (by type and area); make sure MDX page always provides the props (type: festival, gameTime, gamesMarket, tournament, workshop)
const filteredEvents = (allEvents ?? [])
  // Keep only dated event instances (next 10 days); exclude canonical master records
  .filter(event => !event.isCanonical)
  .filter(
    event => !eventTypeFilter || event.typesTranslated?.some(t => t?.code_name === eventTypeFilter)
  )
  .filter(event => !areaCode || event.location?.area?.code_name === areaCode)
---

<section class="events-list">
  {
    !filteredEvents.length && (
      <p class="center">Aucun événement trouvé pour ces critères pour le moment.</p>
    )
  }

  {
    filteredEvents.length > 0 && (
      <IO
        ul
        $skip={!filteredEvents?.[0]?.name}
        class="grid-fluid gap-p list reset"
        style="--width-column-min: var(--width-col-3);"
      >
        <Ad adType="event" />
        {/* <AdEventListMeeple /> */}
        {/* <AdEventListYourAdHere /> */}

        {filteredEvents?.map(event => {
          const {
            name,
            typesTranslated,
            location,
            cover_image,
            organizers,
            time_start,
            time_end,
            isSameDay,
          } = event

          const srcCover = imageDirectusSrc({
            src: cover_image?.src,
            width: '1000',
            fit: 'cover',
            quality: '50',
          })

          const currentTypes = typesTranslated?.map(t => t.code_name)
          const typeAttributes = currentTypes?.reduce(
            (acc, type) => ({ ...acc, [`data-type-${type}`]: true }),
            {}
          )

          const [lng, lat] = location?.geo?.coordinates || []

          return (
            <li
              class="card-event breakout-clickable box no-border no-padding border-radius-s"
              data-types={currentTypes}
              {...typeAttributes}
              data-latitude={lat}
              data-longitude={lng}
            >
              <div
                class="box no-border padding-p with-sidebar gap-p color-palette-trans background-overlay"
                style={
                  (srcCover
                    ? `background-image: url("${srcCover}"); `
                    : `background-image: url("/assets/images/WannaPlay-banner-paper.jpeg");`) +
                  `height: 100%; background-size: cover; background-position: center;`
                }
              >
                <time
                  datetime={time_start.dateTimeRaw}
                  class="timestart flow gap-h8 center intrinsic"
                  style="line-height: 1; --flow-space: var(--size-h8); justify-content: center;"
                >
                  <span class="size-h2">{time_start?.fr?.day}</span>
                  <span class="size-h3">{time_start?.fr?.monthShort}</span>
                  <span class="size-h3">{time_start?.fr?.year}</span>
                </time>
                <div class="flow justify-center align-items-center no-gap">
                  <h2 class="h4 centered">
                    <a href={`/${event.path}/`} class="name reset clickable" set:html={name} />
                  </h2>
                </div>
              </div>
              <div class="card-event-footer box no-border padding-h8 flow horizontal justify-between">
                {/* TODO: repair geting location from organization */}
                <IO
                  p
                  $skipNoInner
                  class="zip city h5"
                  data-zip={location.postalCode}
                  data-city={location.addressLocality}
                  data-latitude={location.geo?.coordinates[1]}
                  data-longitude={location.geo?.coordinates[0]}
                >
                  {location.addressLocality}
                </IO>
                <ul class="reset flow horizontal ">
                  {organizers?.map(({ name, logo }) => (
                    <li>
                      {logo?.src ? (
                        <ImgDirectus
                          image={logo}
                          src={logo?.src}
                          alt={name}
                          loading="lazy"
                          class=""
                          style="width: 2rem; height: 2rem; object-fit:contain;"
                          width="32"
                          height="32"
                          fit="inside"
                          quality="99"
                        />
                      ) : (
                        <Img
                          src={placeholderWPlayCircleBlue}
                          alt="logo"
                          loading="lazy"
                          class=""
                          style="width: 2rem; height: 2rem; object-fit:contain;"
                          width="32"
                          height="32"
                        />
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            </li>
          )
        })}
      </IO>
    )
  }
</section>

<!-- temporary style card for now -->
<style>
  .events-list {
    margin-block: var(--size-h3);
  }
  .card-event {
    display: flex;
    flex-direction: column;
  }
  .card-event.hidden {
    display: none !important;
  }
  .card-event-footer {
    line-height: 32px;
  }
</style>
