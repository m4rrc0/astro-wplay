---
import { Image } from "astro:assets"

// TODO: Check props of the new astro:assets service: https://docs.astro.build/en/guides/images/#properties
const {
  id,
  class: _class,
  style,
  onload,
  image,
  src,
  fit,
  alt,
  width,
  height,
  quality,
  withoutEnlargement,
  format,
  ...props
} = Astro.props || {}
---

<Image
  {...props}
  {src}
  {format}
  {quality}
  {width}
  {height}
  {alt}
  {...id ? { id } : {}}
  {..._class ? { class: _class } : {}}
  {...style ? { style } : {}}
  onload={`this.style.background = 'transparent';${onload || ""}`}
/>
