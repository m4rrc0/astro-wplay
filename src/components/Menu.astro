---
import { createPath } from '@utils'
import { PlayIcon, CalendarIcon, OrgIcon, BxlIcon } from '@partials/icons'
import { MtObf } from '@components'
import { Icon } from 'astro-icon/components'

const { lang: propLang, class: className } = Astro.props

let langFromPathname = Astro.url.pathname.split('/')[1]
langFromPathname = /fr|en|nl/.test(langFromPathname) ? langFromPathname : null
let lang = propLang || (langFromPathname ? { code: langFromPathname } : null)
lang = lang.code ? lang : { code: lang || 'fr' }

const email = import.meta.env.CONTACT_EMAIL

const pageUrl = new URL(Astro.url.pathname, Astro.site)
const isPro = pageUrl.pathname.startsWith('/' + lang.code + '/s/')

const ariaCurrentAttr = currentHref => {
  if (currentHref === pageUrl.pathname) {
    return 'page'
  }
  return false
}
---

<div id="menu-main" class="color-palette-main">
  <nav
    aria-label="Menu principal"
    class="width-max box no-border flow horizontal justify-between"
    style="margin-inline: auto;"
  >
    <!-- Logo -->
    <a
      href={`/${lang.code}/`}
      id="logo"
      class="flow horizontal align-items-center gap-h6"
      aria-label="Page d'accueil"
    >
      <img
        src="/assets/images/favicons/favicon-32x32.png"
        alt="logo"
        width="32"
        height="32"
        style="display: inline;"
      />
      <span>Wanna Play</span>
    </a>
    <!-- Burger menu toggle button -->
    <button
      id="burgerMenuBtn"
      class="navbar-toggler"
      type="button"
      aria-controls="main-menu-list menu-secondary"
      aria-expanded="false"
      aria-label="Open menu"
    >
      <span class="bar top"></span>
      <span class="bar middle"></span>
      <span class="bar bottom"></span>
    </button>
    <!-- Menu items -->
    <!-- <div class="collapse navbar-collapse" id="navbarSupportedContent"> -->
    <ul id="main-menu-list" class="cluster overflow reset reset-down-a size-p gap-h6 justify-end">
      <li>
        <a
          href={`/${lang.code}/guides-pro/`}
          aria-current={ariaCurrentAttr(`/${lang.code}/guides-pro/`)}>Le jeu au travail</a
        >
      </li>
      <li>
        <a
          href={`/${lang.code}/metiers-du-jeu/`}
          aria-current={ariaCurrentAttr(`/${lang.code}/metiers-du-jeu/`)}>Devenir pro</a
        >
      </li>
      <li>
        <a
          href={`/${lang.code}/services/`}
          aria-current={ariaCurrentAttr(`/${lang.code}/services/`)}>Nos services</a
        >
      </li>
      <li>
        <a
          href={`/${lang.code}/a-propos/`}
          aria-current={ariaCurrentAttr(`/${lang.code}/a-propos/`)}>À propos</a
        >
      </li>
      <li>
        <a href={`/${lang.code}/contact/`} aria-current={ariaCurrentAttr(`/${lang.code}/contact/`)}
          >Contact</a
        >
      </li>

      <button class="search-toggle-btn" id="open-search-btn" onclick="searchContainer.showModal()">
        <Icon aria-disabled data-remove-disabled id="searchBtn" name="gridicons:search" />
        <span class="visually-hidden">Rechercher</span>
      </button>
    </ul>
    <!-- </div> -->
  </nav>
</div>
{
  !isPro && (
    <div id="menu-secondary" class="color-palette-variation-funky-contrast">
      <nav aria-label="Secondary menu" class="center width-max box no-border">
        <ul class="cluster overflow reset reset-down-a size-p justify-end gap-h6">
          <li>
            <a href={`/${lang.code}/be/`} aria-current={ariaCurrentAttr(`/${lang.code}/be/`)}>
              <PlayIcon style="height:1.5em;" />
              <span>Jouer en Belgique</span>
            </a>
          </li>
          <li>
            <a href={`/${lang.code}/e/`} aria-current={ariaCurrentAttr(`/${lang.code}/e/`)}>
              <CalendarIcon style="height:1.5em;" />
              <span>Agenda</span>
            </a>
          </li>
          <li>
            <a href={`/${lang.code}/o/`} aria-current={ariaCurrentAttr(`/${lang.code}/o/`)}>
              <OrgIcon style="height:1.5em;" />
              <span>Annuaire</span>
            </a>
          </li>
          <li>
            <a
              href={'/' + createPath({ type: 'areas' }) + '/'}
              aria-current={ariaCurrentAttr('/' + createPath({ type: 'areas' }) + '/')}
            >
              <BxlIcon style="height:1.5em;" />
              <span>Par province</span>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  )
}
<style>
  /* #template-global {
    margin-bottom: var(--gap-xxl);
  } */

  #menu-main {
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 10px rgb(0 0 0 / 20%);
  }
  nav {
    /* --gap: var(--size-h6); */
    /* margin: var(--gap) 0; */
    --justify-content: flex-end;
  }
  /* #menu-main nav > ul > li:first-child, */
  #logo,
  #menu-secondary nav > ul > li:first-child {
    --justify-content: flex-start;
    flex-grow: 1;
  }
  nav > ul > li:first-child > a {
    max-width: max-content;
  }
  nav > ul > li > input {
    padding: 0;
  }
  nav > ul > li > input:hover {
    background-color: initial;
    color: var(--color-text__a--hover);
  }
  [data-icon='gridicons:search'] {
    cursor: pointer;
    color: var(--color-text);
  }
  nav [aria-current='page'] {
    color: var(--color-text__a--hover);
    background-color: var(--color-bg__a--hover);
  }
  #menu-secondary {
    margin-top: 0;
  }
  #menu-secondary li > a {
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }
  #footer-main {
    margin-top: 4vw;
    --skew-before: -1.5deg;
    --skew-before-origin: top left;
  }

  #menu-main #logo {
    flex-grow: 1;
    flex-shrink: 0;
    max-width: max-content;
    text-decoration: none;
    white-space: nowrap;
  }

  #burgerMenuBtn {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 16px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    border-radius: 4px;
  }

  #burgerMenuBtn:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 6px;
  }

  #burgerMenuBtn .bar {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-text);
    border-radius: 4px;
    transition:
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease-in-out;
  }

  #burgerMenuBtn[aria-expanded='true'] .bar.top {
    transform: translateY(7px) rotate(45deg);
  }
  #burgerMenuBtn[aria-expanded='true'] .bar.middle {
    opacity: 0;
  }
  #burgerMenuBtn[aria-expanded='true'] .bar.bottom {
    transform: translateY(-7px) rotate(-45deg);
  }

  .visually-hidden {
    display: none;
  }

  .search-toggle-btn {
    background: transparent;
    border: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    align-items: center;
    font-size: inherit;
    display: flex;
    gap: 0.2rem;
    color: var(--color-text);
  }
  button.search-toggle-btn:has(span.visually-hidden):hover {
    background-color: transparent !important;
    color: var(--color-text);
  }

  @media screen and (max-width: 34rem) {
    html.js #menu-main nav {
      flex-wrap: wrap;
    }

    html.js #burgerMenuBtn {
      display: flex;
    }

    html.js #menu-main ul,
    html.js #menu-secondary ul {
      flex-direction: column;
      width: 100%;
      text-align: center;
      justify-content: flex-end;
      align-items: flex-end;
    }

    html.js #menu-main ul,
    html.js #menu-secondary {
      flex-wrap: nowrap;
      max-height: 0;
      opacity: 0;
      visibility: hidden;

      transition:
        max-height 0.5s ease,
        opacity 0.3s ease,
        visibility 0s 0.4s;
    }

    html.js #menu-main ul.active,
    html.js #menu-secondary.active {
      max-height: 36rem;
      opacity: 1;
      visibility: visible;

      transition:
        max-height 0.5s ease,
        opacity 0.4s ease,
        visibility 0s;
    }

    html.js #menu-main ul li:first-child {
      padding-top: var(--gap);
    }

    html.js #menu-secondary li > a {
      justify-content: center;
    }

    html.js .visually-hidden {
      display: initial;
    }
  }
</style>
<script>
  const burgerBtn = document.getElementById('burgerMenuBtn')
  const navbarMenu = document.querySelector('#menu-main ul')
  const secondaryMenu = document.getElementById('menu-secondary')

  if (burgerBtn) {
    burgerBtn.addEventListener('click', () => {
      const isExpanded = navbarMenu?.classList.toggle('active')
      secondaryMenu?.classList.toggle('active')

      burgerBtn.setAttribute('aria-expanded', isExpanded ? 'true' : 'false')
      burgerBtn.setAttribute('aria-label', isExpanded ? 'Close menu' : 'Open menu')
    })
  }

  document.querySelector('.search-toggle-btn').addEventListener('click', e => {
    e.preventDefault()
    e.stopPropagation()
    const modal = document.getElementById('searchContainer')
    if (modal instanceof HTMLDialogElement) {
      modal.showModal()
    }
  })
</script>
