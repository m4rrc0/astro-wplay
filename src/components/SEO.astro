---
import { getImage } from "astro:assets";
const {
  setViewport = false,
  charset = "",
  siteName = "",
  favicon = "",
  locale = "", // e.g. en_US or fr_BE // og:locale - The locale these tags are marked up in. Of the format language_TERRITORY. Default is en_US.
  localeAlternates = "", // og:locale:alternate - An array of other locales this page is available in.
  ogType = "", // probably "website" or "article" or ...
  title = "",
  description = "",
  canonicalUrl = "",
  socialImage: socialImageRaw = "", // og:image - 1200:630 is recommended according to https://www.kapwing.com/resources/what-is-an-og-image-make-and-format-og-images-for-your-blog-or-webpage/
  ogVideo = "", // og:video - A URL to a video file that complements this object.
  twitterCard = "", // "summary", "summary_large_image", "app", or "player".
  meta = [],
} = Astro.props;

// const titleComposed = title + siteName ? ` | ${siteName}` : ''
const titleComposed = title ? `${title}${siteName ? ` | ${siteName}` : ''}` : siteName

// getImage() requires an imported image object, not a string path.
// To support string paths (e.g. from MDX frontmatter where imports are not possible),
// we dynamically import local paths (/src/... or @..) so getImage() can process them.
const isInternalImage = /^\/src|^\@/.test(socialImageRaw)
const socialImagePath = isInternalImage ? await import(socialImageRaw) : socialImageRaw
const srcRaw = socialImagePath?.default || socialImagePath
const socialImage = srcRaw ? await getImage({ src: srcRaw, alt: title, width: 1200, height: 630 }) : null

---

{charset && <meta {charset} />}

{setViewport && <meta name="viewport" content="width=device-width, initial-scale=1" />}

{locale && <meta property="og:locale" content={locale} />}
{localeAlternates && localeAlternates.map(content => <meta property="og:locale:alternate" {content} />)}

{ogType && <meta property="og:type" content={ogType} />}

{siteName && <meta property="og:site_name" content={siteName} />}

{title &&
  <title>{titleComposed}</title>
  <meta property="og:title" content={titleComposed} />}

{description &&
  <meta name="description" content={description} />
  <meta property="og:description" content={description} />}

{canonicalUrl &&
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:url" content={canonicalUrl} />}

{favicon && <link rel="icon" type="image/png" sizes="32x32" href={favicon} />}

{socialImage?.src &&
	<meta property="og:image" content={socialImage?.src} />
  <meta property="og:image:secure_url" content={socialImage?.src} />
}
{socialImage?.options?.format && <meta property="og:image:type" content={`image/` + socialImage?.options?.format} />}
{socialImage?.attributes?.width && <meta property="og:image:width" content={socialImage?.attributes?.width} />}
{socialImage?.attributes?.height && <meta property="og:image:height" content={socialImage?.attributes?.height} />}
{socialImage?.attributes?.alt && <meta property="og:image:alt" content={socialImage?.attributes?.alt} />}

{ogVideo && <meta property="og:video" content={ogVideo} />}

{twitterCard && <meta name="twitter:card" content={twitterCard} />}
<!-- @username for the website used in the card footer. -->
<!-- <meta name="twitter:site" content="@nytimesbits" /> -->
<!-- @username for the content creator / author. -->
<!-- <meta name="twitter:creator" content="@nickbilton" /> -->

{Array.isArray(meta) && meta.length ? meta.map(m => <meta {...m} />) : null}

<slot />
