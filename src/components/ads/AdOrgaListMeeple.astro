---
import meepleBanner from '@assets/images/ads/banner-meeple.svg'
---

<li
  class="ad-orga-list-meeple box no-border border-radius-s color-palette-main cluster breakout-clickable"
  style={`--bg-image: url('${meepleBanner.src}');`}
>
  <div class="flow content">
    <p class="h2">Ramène ta pub</p>
    <p>Et laisse s’exprimer la star qui sommeil en toi.</p>
  </div>
  <div class="action">
    <a href="" class="button">Proposer un partenariat</a>
  </div>
</li>

<style>
  .ad-orga-list-meeple {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: 15rem;
    grid-column: 1 / -1;
    grid-row: 1 / 2;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    background-color: #e4edfb;
  }

  .ad-orga-list-meeple::after {
    content: '';
    position: absolute;
    top: 66.66%;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--bg-image) center top / 100% auto no-repeat;
    z-index: -1;
    pointer-events: none;
  }

  .ad-orga-list-meeple .content {
    --flow-space: 0.7em;
    flex-basis: 20rem;
    /* flex-grow: 1; */
  }

  .ad-orga-list-meeple .action {
    margin-inline: auto;
  }

  .ad-orga-list-meeple .action a.button {
    display: block;
    width: 100%;
    text-decoration: none;
    padding-inline: 0.5em;
    border-radius: var(--border-radius-s);
    background-color: var(--color-neutral);
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }
  .ad-orga-list-meeple .action a.button:hover {
    background-color: var(--color-primary);
    color: white;
  }

  @media (min-width: 55rem) {
    .ad-orga-list-meeple {
      grid-column: 2 / -1;
    }
  }
  @media (min-width: 70rem) {
    .ad-orga-list-meeple {
      grid-column: 3 / -1;
    }
  }
</style>
