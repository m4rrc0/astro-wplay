---
import path from 'node:path'
// this file is a general layout for all .md pages
import { SkeletonPage, BasicPage } from '@layouts'
import { SEO } from '@components'

const frontmatter = Astro.props.frontmatter
// default lang (fr) to avoid undefined
const lang = Astro.props.lang ?? { code: 'fr' }

const pageUrl = new URL(Astro.url.pathname, Astro.site)
const canonicalUrl = (pageUrl.href + '/').replace(/[\/]+$/, '/')

const {
  siteName,
  locale, // e.g. en_US or fr_BE
  ogType, // probably "website" or "article" or ...
  title,
  description,
  socialImage,
  twitterCard, // "summary", "summary_large_image", "app", or "player".
  ogVideo, // og:video - A URL to a video file that complements this object.
} = frontmatter
---

<SkeletonPage lang={lang.code}>
  <SEO
    slot="head"
    {siteName}
    {locale}
    {ogType}
    {title}
    {description}
    {canonicalUrl}
    {socialImage}
    {twitterCard}
    {ogVideo}
  />
  <BasicPage {lang}>
    <main class="layout-markdown_page center max flow v--flow-space:1em">
      <slot />
    </main>

    <style>
      /* Astro scoped styles do NOT apply to slotted content by default */
      :global(.layout-markdown_page > p) {
        --flow-space: 0.4em;
      }
      :global(.layout-markdown_page > ul) {
        --flow-space: 0.7em;
      }
      :global(.layout-markdown_page > h3) {
        --flow-space: 1.1em;
      }
      :global(.layout-markdown_page > h2) {
        --flow-space: 1.2em;
      }
      :global(.img-banner img) {
        width: 100%;
        height: 250px;
        object-fit: cover;
        display: block;
      }
      :global(.card.flow > *) {
        --flow-space: 0.25em;
      }
      :global(.card-team) {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      :global(.video-container) {
        width: 100%;
        justify-content: center;
      }

      :global(.video-container iframe, .video-container lite-youtube) {
        width: 100%;
        aspect-ratio: 16 / 9;
        border-radius: var(--border-radius-l);
      }

      :global(.video-grid iframe) {
        width: 50%;
        aspect-ratio: 16 / 9;
        border-radius: var(--border-radius-l);
      }

      :global(.type-list a) {
        box-sizing: border-box;
        border: 3px solid var(--color-bg__button);
        text-decoration: solid underline currentColor 2px;
        --color-border__button--hover: var(--color-bg);

        &:hover {
          border-color: currentColor;
          color: var(--color-bg);
          text-decoration-color: var(--color-bg);
        }
      }
    </style>
  </BasicPage>
</SkeletonPage>
