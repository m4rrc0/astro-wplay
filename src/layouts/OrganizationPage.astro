---
import path from 'node:path'
import { Markdown } from '@components'
import { Icon } from 'astro-icon/components'
import { SkeletonPage, BasicPage } from '@layouts'
import { SEO, IO, ImgDirectus } from '@components'
import { imageDirectusSrc, getImage } from '@utils'
import badge from '@assets/images/badge.png'

const {
  lang,
  organization: {
    // status,
    // date_updated,
    name,
    // slug,
    // types,
    typesTranslated,
    jsonldType,
    logo,
    cover_image,
    // opening_hours,
    opening_hours_strings,
    servicesTranslated,
    location,
    // amenities,
    amenities_translated,
    website,
    facebook_page,
    instagram,
    twitter,
    youtube_channel,
    translations,
    // gallery,
    areaServedByArea,
    links,
    admin_categories,
    events: eventsUnfiltered,
    canonicalEvents,
  },
} = Astro.props

const events = eventsUnfiltered?.filter(e => !e.isCanonical)
const eventsLd = [...canonicalEvents, ...eventsUnfiltered]
  ?.filter(e => {
    // console.log({ e })
    return e.recurrence === 'unique' || e.recurrence === 'multidays' || e.isCanonical
  })
  .map(event => {
    const baseUrl = new URL(event.path, Astro.site).href

    const isSeries = event.isRecurring
    const type = isSeries ? 'EventSeries' : 'Event'
    const locationName = event?.location?.name

    const eventStub = {
      '@type': type,
      '@id': baseUrl + '#' + type,
      name: event.name,
      url: baseUrl,
      ...(isSeries
        ? {}
        : {
            startDate: event?.time_start?.dateTimeRaw,
            endDate: event?.time_end?.dateTimeRaw,
          }),
      location: {
        '@type': 'Place',
        ...(locationName ? { name: locationName } : {}),
        address: {
          '@type': 'PostalAddress',
          ...(event.location.streetAddress ? { streetAddress: event.location.streetAddress } : {}),
          ...(event.location.addressLocality
            ? { addressLocality: event.location.addressLocality }
            : {}),
          ...(event.location.postalCode ? { postalCode: event.location.postalCode } : {}),
          addressCountry: 'BE',
        },
      },
    }
    return eventStub
  })

const { description, opening_hours_remark, rich_text_content, opening_hours_notes } =
  translations?.find(({ languages_code }) => languages_code === lang.code) || {}
const presentationInStr =
  location?.area?.code_name === 'france'
    ? ' en France'
    : ` dans la ${
        location?.area?.code_name === 'brussels' ? 'région' : 'province'
      } de ${location?.area?.name?.fr}`
const presentation =
  typesTranslated?.[0] &&
  location?.addressLocality &&
  location?.area?.name?.fr &&
  typesTranslated
    ?.map(type => type.translations.find(t => t.language_code === lang.code).default_label)
    .join(', ') +
    ` à ${location.addressLocality}` +
    (location.addressLocality !== location?.area?.name?.fr ? presentationInStr : '')
const srcCover = imageDirectusSrc({
  src: cover_image?.src,
  width: '1300',
  fit: 'cover',
  quality: '50',
})
const srcSocial = imageDirectusSrc({
  src: cover_image?.src || logo?.src,
  width: '1200',
  height: '630',
  fit: 'cover',
  quality: '99',
})

const pageUrl = new URL(Astro.url.pathname, Astro.site)
const canonicalUrl = (pageUrl.href + '/').replace(/[\/]+$/, '/')

// let jsonldType
const allowedSameAs = [
  'website',
  'web_page',
  'twitch',
  'linkedin',
  'facebook',
  'facebook_page',
  'instagram',
  'twitter',
  'youtube',
  'youtube_channel',
  'tiktok',
  'tripadvisor',
  'linktree',
]
const linksSameAsRaw = links?.filter(link => allowedSameAs.includes(link.name?.code_name))
const linksSameAs = linksSameAsRaw?.map(link => link.url) || []

const logoLd = logo ? await getImage({ ...logo }) : null
const imageLd = cover_image ? await getImage({ ...cover_image }) : null

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': jsonldType,
  '@id': pageUrl.href + '#Organization',
  url: pageUrl.href,
  name,
  // legalName: name,
  description: presentation,
  ...(logoLd?.src && { logo: logoLd.src }),
  ...(imageLd?.src && { image: imageLd.src }),
  ...(location && {
    location: {
      '@type': 'Place',
      ...(location?.name ? { name: location?.name } : {}),
      address: {
        '@type': 'PostalAddress',
        ...(location.streetAddress ? { streetAddress: location.streetAddress } : {}),
        ...(location.addressLocality ? { addressLocality: location.addressLocality } : {}),
        ...(location.postalCode ? { postalCode: location.postalCode } : {}),
        addressCountry: 'BE',
      },
    },
  }),
  ...(linksSameAs && { sameAs: linksSameAs }),
  ...(eventsLd.length && { event: eventsLd }),
}

if (location?.geo?.coordinates && jsonldType !== 'Organization') {
  jsonLd.geo = {
    '@type': 'GeoCoordinates',
    longitude: location.geo.coordinates[0],
    latitude: location.geo.coordinates[1],
  }
}

if (areaServedByArea.length) {
  jsonLd.areaServed = areaServedByArea.map(area => {
    const { default_label } = area.tag.translations.find(t => t.language_code === lang.code) || {}
    return {
      '@type': 'AdministrativeArea',
      name: default_label || area.tag.code_name,
    }
  })
}

if (jsonldType === 'Library') {
  jsonLd.amenityFeature = {
    '@type': 'LocationFeatureSpecification',
    name: 'Ludothèque',
    // value: 'true',
  }
}

// TODO: Add
// - additional types
// - opening hours
// - servicesTranslated -> amenityFeature??
// - ...
---

<!-- <Debug {name} /> -->
<SkeletonPage lang={lang.code}>
  <SEO
    slot="head"
    ogType="website"
    title={name}
    description={presentation}
    {canonicalUrl}
    socialImage={srcSocial || '/assets/images/LOGO-1024px.png'}
    ogVideo={false}
    twitterCard="summary"
  />
  <BasicPage {lang}>
    <main class="max" style="margin-top: 0;">
      <header>
        <div
          class="flex center text box no-border flow gap-h7
            color-palette-trans
            h2 padding-y-relative-xl
            background-overlay"
          style={srcCover
            ? `background-image: url("${srcCover}");`
            : 'background-image: url("/assets/images/WannaPlay-banner-paper.jpeg");'}
        >
          <h1 class="centered" set:html={name} />
          {presentation && <p class="h4">{presentation}</p>}
          {
            location?.string && (
              <p class="h6">
                <a href={location.gMapLink} target="_blank" rel="noopener noreferrer nofollow">
                  {location.string}
                </a>
              </p>
            )
          }
        </div>
        {
          logo?.src && (
            <div
              class={`center intrinsic box no-border
              color-palette-main
              width-col-6
              border-radius-s
              ${admin_categories?.includes('badge_default') || admin_categories?.includes('paid_partner') ? 'badge' : ''}`}
              style={`
              margin-top: calc(var(--size-h3) * -1);
              margin-bottom: var(--size-h3);
              box-shadow: 0 0px 6px rgb(0 0 0 / 30%);
              overflow: hidden;
              --badge-url: url(${badge.src});
              `}
            >
              <ImgDirectus
                image={logo}
                src={logo?.src}
                alt={name}
                loading="lazy"
                class=""
                style={`width: ${logo.width}; max-width: 100%; height: auto; max-height: ${logo.height}; object-fit: contain;`}
                width={logo.width}
                height={logo.height}
                fit="contain"
                quality="99"
              />
            </div>
          )
        }
      </header>

      {
        (servicesTranslated?.[0] || amenities_translated?.[0]) && (
          <ul class="box no-border center max-width-measure-p cluster padding-h6 gap-p">
            <>
              {servicesTranslated?.map(service => (
                <li
                  class="
                    box no-border padding-x-h7 padding-y-h8
                    color-palette-variation-contrast
                    border-radius-s
                  "
                >
                  {service.translations.find(t => t.language_code === lang.code).default_label}
                </li>
              ))}

              {amenities_translated?.map(({ [lang.code]: code }) => (
                <li
                  class="
                  box no-border padding-x-h7 padding-y-h8
                  color-palette-variation-funky-contrast
                  border-radius-s
                "
                >
                  {code}
                </li>
              ))}
            </>
          </ul>
        )
      }

      {
        (opening_hours_strings?.[0] || opening_hours_remark || opening_hours_notes) && (
          <div class="box no-border color-palette-variation-funky-contrast">
            <div class="center max-width-measure-p flow gap-h7 recursive">
              <h2>Horaires</h2>
              {opening_hours_strings?.[0] && (
                <div class="flow gap-h9">
                  {opening_hours_strings.map(str => (
                    <p set:html={str} />
                  ))}
                </div>
              )}
              {(opening_hours_notes && <div class="" set:html={opening_hours_notes} />) ||
                (opening_hours_remark && (
                  <div class="">
                    <Markdown content={opening_hours_remark} />
                  </div>
                ))}
            </div>
          </div>
        )
      }
      <!-- {amenities_translated?.[0] && <div class="box no-border cluster gap-h6">
        <ul class="reset">
            {amenities_translated?.map(({ [lang.code]: code }) => (
              <li>{code}</li>
            ))}
        </ul>
      </div>} -->

      {
        (rich_text_content && (
          <div
            class="
        rich-text-content
        box no-border center
        max-width-measure-p
        flow
      "
            set:html={rich_text_content}
          />
        )) ||
          (description && (
            <div
              class="
        description
        box no-border center
        max-width-measure-p
        flow
      "
            >
              <h2>Description</h2>
              <Markdown content={description} class="flow" />
            </div>
          ))
      }

      {
        links?.[0] && (
          <ul class="reset cluster justify-center">
            {links.map(({ name, url, iconName }) => {
              const followPolicy = name?.code_name === 'website' ? 'dofollow' : 'nofollow'
              return (
                <li>
                  <a
                    href={url}
                    target="_blank"
                    rel={`noopener noreferrer ${followPolicy}`}
                    class="
                  box no-border flow center intrinsic
                "
                  >
                    <Icon name={iconName} size="1em" class="size-h2" />
                    <div class="size-p">{name.fr}</div>
                  </a>
                </li>
              )
            })}
          </ul>
        )
      }
      {
        events?.[0] && (
          <div class="box no-border flow">
            <h2>Prochains événements</h2>
            <IO
              ul
              $skip={!events?.[0]?.name}
              class="grid-fluid gap-p list reset"
              style="--width-column-min: var(--width-col-3);"
            >
              {events?.map(event => {
                const { name, location, cover_image, time_start } = event

                const srcCover = imageDirectusSrc({
                  src: cover_image?.src,
                  width: '1000',
                  fit: 'cover',
                  quality: '50',
                })

                return (
                  <li
                    class="card-event breakout-clickable box no-border no-padding border-radius-s"
                    style=""
                  >
                    <div
                      class="box no-border padding-p with-sidebar gap-p color-palette-trans background-overlay"
                      style={
                        srcCover
                          ? `background-image: url("${srcCover}"); `
                          : `background-image: url("/assets/images/WannaPlay-banner-paper.jpeg");`
                      }
                    >
                      <time
                        datetime={time_start.dateTimeRaw}
                        class="timestart flow gap-h8 center intrinsic"
                        style="line-height: 1;"
                      >
                        <span class="size-h2">{time_start?.fr?.day}</span>
                        <span class="size-h3">{time_start?.fr?.monthShort}</span>
                        <span class="size-h3">{time_start?.fr?.year}</span>
                      </time>
                      <div class="flow justify-center align-items-center no-gap">
                        <h2 class="h4 centered">
                          <a
                            href={`/${event.path}/`}
                            class="name reset clickable"
                            set:html={name}
                          />
                        </h2>
                      </div>
                    </div>
                    <div class="card-event-footer box no-border padding-h8 flow horizontal justify-between">
                      <IO
                        p
                        $skipNoInner
                        class="zip city h5"
                        data-zip={location?.postalCode}
                        data-city={location?.addressLocality}
                      >
                        {location?.addressLocality}
                      </IO>
                    </div>
                  </li>
                )
              })}
            </IO>
          </div>
        )
      }
    </main>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </BasicPage>
</SkeletonPage>
<style>
  section {
    padding-block: var(--size-h2);
  }

  div.flow > * {
    --flow-space: var(--gap-h3);
  }

  .badge {
    position: relative;
    overflow: visible !important;
  }
  .badge::after {
    content: '';
    position: absolute;
    top: -16px;
    right: -16px;
    width: 52px;
    aspect-ratio: 1;
    background-image: var(--badge-url);
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
    pointer-events: none;
    z-index: 10;
    filter: drop-shadow(0 0 2px rgba(0, 0, 0, 0.5));
  }
</style>
