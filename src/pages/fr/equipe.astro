---
import { SkeletonPage, BasicPage } from "@layouts"
import { SEO, Img } from "@components"

import jenny from "@images/team/WannaPlayTeam_Jenny.png"
import jo from "@images/team/WannaPlayTeam_Jo.jpg"
import marc from "@images/team/WannaPlayTeam_Marc.jpg"
import pierre from "@images/team/WannaPlayTeam_Pierre.png"
import tess from "@images/team/WannaPlayTeam_Tess.jpg"
import yves from "@images/team/WannaPlayTeam_Yves.jpg"

const team = [
  { pic: marc, name: "Marc" },
  { pic: tess, name: "Tess" },
  { pic: jo, name: "Jo" },
  { pic: yves, name: "Yves" },
  { pic: jenny, name: "Jenny" },
  { pic: pierre, name: "Pierre" },
]

const canonicalURL = new URL(Astro.url.pathname, Astro.site)
---

<SkeletonPage lang="fr">
  <SEO
    slot="head"
    ogType="website"
    title="L'équipe"
    description="Viens découvrir qui se cache derrière Wanna Play"
    canonicalUrl={canonicalURL.href}
    socialImage="/assets/images/LOGO-1024px.png"
    ogVideo={false}
    twitterCard="summary"
  />

  <BasicPage lang={{ code: "fr" }}>
    <main class="max-width-measure-h2 center max stack gap-down-h1">
      <h1 class="center text">L'équipe</h1>

      <div class="grid" style="--width-column: 8rem;">
        <div>
          {team.map(({ pic, name }) => {
            return (
              <div>
                <Img
                  src={pic}
                  alt=""
                  loading="lazy"
                  class=""
                  style="width: 15rem; max-height: 15rem; max-width: 100%; height: auto;"
                  width="240"
                  height="240"
                />
                <p class="center text">{name}</p>
              </div>
            )
          })}
        </div>
      </div>
    </main>
  </BasicPage>
</SkeletonPage>

<style>
  img {
    max-width: 100%;
    height: auto;
  }
</style>
