  { fileName: 'logo-wana-game', alt: 'Logo Wana Game', link: '' },
  { fileName: 'logo-foxtroll-games', alt: 'Logo Foxtroll Games', link: '' },
  { fileName: 'logo-ploef', alt: 'Logo Ploef', link: '' },
  { fileName: 'logo-auberjeux', alt: 'Logo Auberjeux', link: '' },
  { fileName: 'logo-ludiris-asbl', alt: 'Logo Ludiris asbl', link: '' },
  { fileName: 'logo-sdc', alt: 'Logo SDC', link: '' },
  { fileName: 'logo-le-game-au-vert', alt: 'Logo Le Game au Vert', link: '' },
  { fileName: 'logo-ludenne', alt: 'Logo Ludenne', link: '' },
  { fileName: 'logo-ludo-ludo', alt: 'Logo Ludo Ludo', link: '' },
  { fileName: 'quentin-lammerant', alt: 'Quentin Lammerant', link: '' },
  { fileName: 'logo-des-mentiel', alt: 'Logo Des Mentiel', link: '' },
  { fileName: 'logo-au-fil-des-mot', alt: 'Logo Au Fil des Mots', link: '' },
  { fileName: 'logo-yapaka', alt: 'Logo Yapaka', link: '' },
  { fileName: 'logo-alpa-ludismes', alt: 'Logo Alpa Ludismes', link: '' },
  { fileName: 'logo-des-jeux-une-fois', alt: 'Logo Des Jeux Une Fois', link: '' },
]

const allSlugs = [...mainPartnersData, ...conferenceData, ...vipData, ...generalData].map(p =>
  p.fileName.replace(/^logo-/, '')
)

const organizations = await getOrganizations({
  filter: {
    _and: [{ status: { _in: ['published', 'to_check'] } }, { slug: { _in: allSlugs } }],
  },
})

const partners = import.meta.glob<{ default: ImageMetadata }>(
  '@assets/images/partners/*.{jpeg,jpg,png,gif,webp,svg}',
  { eager: true }
)

async function getOptimizedImages(dataArray, globImages, organizations, width = 300) {
  const result = await Promise.all(
    dataArray.map(async partner => {
      const pathImage = Object.keys(globImages).find(path => path.includes(partner.fileName))
      const originalImage = pathImage ? globImages[pathImage].default : null
      let optimizedImage = null
      if (originalImage) {
        optimizedImage = await getImage({
          src: originalImage,
          width,
        })
      }

      const slug = partner.fileName.replace(/^logo-/, '')
      const org = organizations.find(o => o.slug === slug)

      let finalLink = null
      if (org) {
        finalLink = `/fr/o/${org.slug}/`
      } else if (partner.link) {
        finalLink = partner.link
      }

      return {
        img: originalImage,
        optimizedMeta: optimizedImage,
        alt: partner.alt || partner.name,
        displayName: partner.name || partner.alt,
        fileName: partner.fileName,
        finalLink,
      }
    })
  )
  return result.filter(p => p.img)
}

const imagesMainPartners = await getOptimizedImages(mainPartnersData, partners, organizations)
const imagesConferencePartners = await getOptimizedImages(conferenceData, partners, organizations)
const imagesVipPartners = await getOptimizedImages(vipData, partners, organizations)
const imagesGeneralPartners = await getOptimizedImages(generalData, partners, organizations)

// const { lang } = Astro.props
const lang = { code: 'fr' }
