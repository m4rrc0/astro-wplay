---
import { SkeletonPage, BasicPage } from '@layouts'
import { SEO } from '@components'
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import getOptimizedImages from '../../../utils/getOptimizedImages.js'
import GalleryFull from '@partials/GalleryFull.astro'

const lang = { code: 'fr' }

const partnersData = [
  { fileName: 'logo-asmo', alt: 'Logo Asmodee' },
  { fileName: 'logo-espace-careme', alt: 'Logo Bibliothèque Anderlecht (Espace Carême)' },
  { fileName: 'logo-ludivine', alt: 'Logo Ludivine devenu Ludothèque Au Coin Des Jeux' },
  { fileName: 'logo-casse-noisettes', alt: 'Logo Casse-Noisettes' },
  { fileName: 'logo-lets-play-together', alt: "Logo Let's Play Together" },
  { fileName: 'logo-the-cookie-tree', alt: 'Logo The Cookie Tree' },
  { fileName: 'logo-jeux-spellen', alt: 'Logo Jeux Spellen' },
  { fileName: 'logo-g-a-g', alt: 'Logo Geek Attitude Games' },
  { fileName: 'logo-jeuxsticiers', alt: 'Logo Jeuxsticiers' },
  { fileName: 'logo-ace-workshops', alt: 'Logo Ace Workshops' },
  { fileName: 'logo-repos-production', alt: 'Logo Repos Production' },
  { fileName: 'logo-de-joueur', alt: 'Logo De Joueur' },
  { fileName: 'logo-govinda', alt: 'Logo Govinda' },
  { fileName: 'logo-des-jeux-une-fois', alt: 'Logo Des Jeux une fois' },
]

const allSlugs = [...partnersData.map(p => p.fileName.replace(/^logo-/, ''))]

import { getOrganizations } from '../../../store/dataService.js'

const organizations = await getOrganizations({
  filter: {
    _and: [{ status: { _in: ['published', 'to_check'] } }, { slug: { _in: allSlugs } }],
  },
})

const partners = import.meta.glob<{ default: ImageMetadata }>(
  '@assets/images/partners/*.{jpeg,jpg,png,gif,webp,svg}'
)

const imagesPartners = await getOptimizedImages(partnersData, partners, organizations)

const inaugurationPhotos = Object.values(
  import.meta.glob<{ default: ImageMetadata }>('../../../assets/images/inauguration-2018/*.webp', {
    eager: true,
  })
)

const imagesIris = import.meta.glob<{ default: ImageMetadata }>(
  '@assets/images/inauguration-2018/iris-senden/*.{jpeg,jpg,png,gif,webp,svg}'
)
const imagesVeronique = import.meta.glob<{ default: ImageMetadata }>(
  '@assets/images/inauguration-2018/veronique-bosschaert/*.{jpeg,jpg,png,gif,webp,svg}'
)

const imagesIndiaTeoTess = import.meta.glob<{ default: ImageMetadata }>(
  '@assets/images/inauguration-2018/india-teo-tess/*.{jpeg,jpg,png,gif,webp,svg}'
)
---

<SkeletonPage {lang}>
  <SEO
    slot="head"
    ogType="website"
    title="Inauguration Wanna Play - 10 juin 2018"
    description="Retour sur l'événement fondateur de Wanna Play : l'invocation de Ruego."
    socialImage={'/archive/images/mailChimp_header-invitation-2.png'}
    ogVideo={false}
    twitterCard="summary"
  />

  <BasicPage {lang}>
    <main class="center max" style="margin-top: 0;">
      <header
        class="flex center text flow items-center gap-h7 color-palette-trans background-overlay padding-y-relative-xl"
        style='background-image: url("/assets/images/WannaPlay-banner-paper.jpeg");'
      >
        <h1>Inauguration</h1>
        <p><strong>Dimanche 10 juin 2018 à 16h</strong></p>
      </header>

      <section class="flow gap-h4 padding-y-h1">
        <p>
          En juin 2018, Wanna Play organise son tout premier événement: l’inauguration officielle du
          projet. Un moment important pour l’équipe… mais surtout une première rencontre avec la
          communauté.
        </p>

        <p>
          Pour cette première soirée, joueurs curieux, passionnés, partenaires et animateurs
          répondent présents. On présente le concept d'inscription à une table de jeu, grâce à notre
          application web. Les règles s’expliquent, les parties s’enchaînent… et l’ambiance
          s’installe naturellement.
        </p>

        <p>
          Cette inauguration à permis de faire connaître le projet, d'organiser un concours, de
          rencontrer des joueurs et des partenaires. Cela marque le début des événements Wanna Play
          et confirme l’envie de créer des moments de rencontre autour du jeu.
        </p>
      </section>

      <h2>Objectifs de l’événement</h2>

      <ul>
        <li>Présenter le projet Wanna Play au public</li>
        <li>Faire découvrir les jeux de société modernes</li>
        <li>Créer des rencontres entre joueurs</li>
        <li>Réunir les acteurs du monde ludique</li>
      </ul>

      <!-- Stats -->
      <section class="flow gap-h4 padding-y-h1">
        <ul class="reset grid-fluid" style="--width-column-min: var(--width-col-8);">
          <li
            class="box no-border padding-h4 gap-h4 color-palette-trans background-overlay border-radius-s text-center stat"
          >
            <p class="h1">+110</p>
            <p>joueurs</p>
          </li>
          <li
            class="box no-border padding-h4 gap-h4 color-palette-trans background-overlay border-radius-s text-center stat"
          >
            <p class="h1">11</p>
            <p>partenaires</p>
          </li>
          <li
            class="box no-border padding-h4 gap-h4 color-palette-trans background-overlay border-radius-s text-center stat"
          >
            <p class="h1">+70</p>
            <p>jeux proposés</p>
          </li>
          <li
            class="box no-border padding-h4 gap-h4 color-palette-trans background-overlay border-radius-s text-center stat"
          >
            <p class="h1">40</p>
            <p>tables créées</p>
          </li>
          <li
            class="box no-border padding-h4 gap-h4 color-palette-trans background-overlay border-radius-s text-center stat"
          >
            <p class="h1">16</p>
            <p>interviews</p>
          </li>
          <li
            class="box no-border padding-h4 gap-h4 color-palette-trans background-overlay border-radius-s text-center stat"
          >
            <p class="h1">8</p>
            <p>jeux offerts (Asmodee)</p>
          </li>
        </ul>
      </section>

      <h2>Activités</h2>
      <h3>Tables de jeux</h3>

      <p>
        Des tables animées par les partenaires et l’équipe Wanna Play ont permis aux visiteurs de
        découvrir de nombreux jeux de société modernes.
      </p>

      <h3>Découverte et rencontres</h3>

      <p>
        L’événement a permis aux joueurs de rencontrer d’autres passionnés, découvrir de nouveaux
        jeux et échanger avec les acteurs du monde ludique.
      </p>

      <!-- Partenaires -->
      <section class="flow gap-h4 padding-y-h1">
        <h2>Partenaires</h2>
        <div class="partners-grid">
          {/* On boucle sur le tableau des images */}
          {
            imagesPartners.map(({ optimizedMeta, alt, finalLink }) => {
              const imgTag = <img src={optimizedMeta.src} {...optimizedMeta.attributes} alt={alt} />
              return finalLink ? (
                <a href={finalLink} target={finalLink.startsWith('http') ? '_blank' : ''}>
                  {imgTag}
                </a>
              ) : (
                imgTag
              )
            })
          }
        </div>
      </section>

      <!-- Visibilité -->
      <section class="flow gap-h4 padding-y-h1">
        <h2>Visibilité</h2>
        <ul class="flow">
          <li>flyer</li>
          <li>tampons</li>
          <li>jetons</li>
          <li>newsletter</li>
          <li>post réseaux sociaux</li>
          <li>musique et effet sonore</li>
        </ul>
        <div class="photos-grid grid-fluid gap-h4" style="--columns: 3;">
          {inaugurationPhotos.map(mod => <Image src={mod.default} alt="" />)}
        </div>
      </section>

      <!-- Vidéo -->
      <section class="flow gap-h4 padding-y-h1">
        <h2>Souvenirs en vidéo</h2>
        <div class="video-container">
          <iframe src="https://www.youtube.com/embed/laySniWhIU4" frameborder="0" allowfullscreen>
          </iframe>
        </div>
      </section>
      <!-- Autres vidéos -->
      <section class="flow gap-h4 padding-y-h1">
        <div class="more-videos grid-fluid gap-h4" style="--columns: 2;">
          <iframe
            width="560"
            height="315"
            src="https://www.youtube.com/embed/EN-lcEHG0Hs?si=mRSzhD0Lyv6eYS6W"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          >
          </iframe>
          <iframe
            width="560"
            height="315"
            src="https://www.youtube.com/embed/mm7Ns9f2HOo?si=3w84Q5h4ptOvL89v"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          >
          </iframe>
          <iframe
            width="560"
            height="315"
            src="https://www.youtube.com/embed/xuprLDbqVBo?si=olP5sj9AJUI8Nmhj"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          >
          </iframe>
          <iframe
            width="560"
            height="315"
            src="https://www.youtube.com/embed/6ETJeapT3RU?si=3IiKbZUpJFNisz-W"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          >
          </iframe>
          <iframe
            width="560"
            height="315"
            src="https://www.youtube.com/embed/QXAKaPxA7Ws?si=2hVHoR6MiJP4k_Av"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          >
          </iframe>
          <iframe
            width="560"
            height="315"
            src="https://www.youtube.com/embed/rvrQFy85oX4?si=jBQGXj6c5Z0-SErm"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          >
          </iframe>
          <iframe
            width="560"
            height="315"
            src="https://www.youtube.com/embed/d1-UE918_QA?si=Ukwl8H2lG4VdS7kT"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          >
          </iframe>
          <iframe
            width="560"
            height="315"
            src="https://www.youtube.com/embed/xj5RawWEDzc?si=UU7dwfOMsGUAa6Tt"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          >
          </iframe>
        </div>
      </section>

      <!-- Gallerie photos -->
      <section>
        <h2>Photos</h2>
        <h3>Photos © Iris Senden</h3>
        <GalleryFull images={imagesIris} />
        <h3>Photos © Véronique Bosschaert</h3>
        <GalleryFull images={imagesVeronique} />
        <h3>Photos © India Hadri, Teodora Rusu & <a href="https://www.tess-h.be">Tess h.</a></h3>
        <GalleryFull images={imagesIndiaTeoTess} />
      </section>
    </main>
  </BasicPage>
</SkeletonPage>

<style>
  /* Tilted "sur place" card */
  .sur-place-box {
    transform: rotate(-3deg);
    margin: var(--size-h3) auto;
    width: 90%;
    max-width: 600px;
    box-shadow: var(--shadow-raised-s);
  }

  /* Stat numbers — use color-primary from palette */
  .stat-nb {
    font-weight: bold;
    color: var(--color-primary);
    margin: 0;
  }
  /* Partner logos */
  .partner-logo {
    height: 70px;
    width: 70px;
    object-fit: contain;
  }
  .partners-grid {
    display: grid;
    /* 6 colonnes par défaut, qui s'adaptent si l'écran est plus petit */
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: var(--size-h2);
    align-items: center;
    justify-items: center;
    margin-bottom: var(--size-h2);
  }

  @media (min-width: 1024px) {
    .partners-grid {
      grid-template-columns: repeat(8, 1fr);
    }
  }
  .partners-grid img {
    max-width: 100%;
    height: auto;
    object-fit: contain;
    max-height: 100px;
  }

  .photos-grid img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  .video-container {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .video-container iframe {
    width: 66.66%;
    aspect-ratio: 16 / 9;
    border-radius: var(--border-radius-l);
  }

  .more-videos iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--border-radius-l);
  }
  .stat {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding-bottom: var(--size-h1);
  }
  section {
    padding-block: var(--size-h1);
  }
  div.flow > * {
    --flow-space: var(--gap-h2);
  }
</style>
