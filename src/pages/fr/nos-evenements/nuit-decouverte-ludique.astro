  },
  {
    fileName: 'logo-scorpion-masque',
    alt: 'Logo de Scorpion Masqué',
    link: 'https://www.scorpionmasque.com',
  },
  {
    fileName: 'logo-sit-down',
    alt: 'Logo de Sitdown Games',
    link: '',
  },
  {
    fileName: 'logo-space-cowboys',
    alt: 'Logo de Space Cowboys',
    link: 'https://www.spacecowboys-games.com/',
  },
  {
    fileName: 'logo-studio-bombyx',
    alt: 'Logo de Studio Bombyx',
    link: 'https://studiobombyx.com/',
  },
]

const allSlugs = [...partnersData].map(p => p.fileName.replace(/^logo-/, ''))

const organizations = await getOrganizations({
  filter: {
    _and: [{ status: { _in: ['published', 'to_check'] } }, { slug: { _in: allSlugs } }],
  },
})

const partners = import.meta.glob<{ default: ImageMetadata }>(
  '@assets/images/partners/*.{jpeg,jpg,png,gif,webp,svg}'
)

const imagesPartners = await getOptimizedImages(partnersData, partners, organizations)

const images = import.meta.glob<{ default: ImageMetadata }>(
  '@assets/images/nuit-decouverte-ludique-2018/*.{jpeg,jpg,png,gif,webp,svg}'
)
---

<SkeletonPage {lang}>
  <SEO
    slot="head"
    ogType="website"
    title="La nuit des découvertes ludiques - BGF 2018"
    description="Retour sur une nuit de découvertes avec plus de 50 nouveautés jouables toute la nuit au Brussels Games Festival 2018."
    socialImage={'https://www.placeholderimage.eu/1200x630'}
    ogVideo={false}
    twitterCard="summary"
  />

  <BasicPage {lang}>
    <main class="center max stack gap-down-h3" style="margin-top: 0;">
      <!-- Header -->
      <header
        class="center text flow items-center color-palette-trans background-overlay padding-y-relative-xl"
        style='background-image: url("/assets/images/WannaPlay-banner-paper.jpeg");'
      >
        <h1>
          Brussels Games Festival 2018<br />
          La nuit des découvertes ludiques
        </h1>
      </header>

      <!-- Intro -->
      <section class="flow padding-x-relative-l">
        <p class="size-h3"><strong>Une nuit de découvertes ludiques</strong></p>
        <p>
          Plus de 50 nouveautés 2018 étaient disponibles toute la nuit au Brussels Games Festival
          grâce à la complicité de nos partenaires éditeurs et distributeurs.
        </p>
        <div class="video-container">
          <iframe
            src="https://www.youtube.com/embed/Z895F3XZ-sg?si=xk0QdQu9DTQfUMT2"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
            style="max-width: 100%; border-radius: var(--border-radius-m);"></iframe>
        </div>
      </section>

      <!-- Stats -->
      <section>
        <ul class="reset grid-fluid" style="--width-column-min: var(--width-col-8);">
          <li
            class="stat box no-border padding-h4 color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h1">+50</p>
            <p>nouveautés 2018</p>
          </li>
          <li
            class="stat box no-border padding-h4 color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h1">~100</p>
            <p>parties jouées</p>
          </li>
          <li
            class="stat box no-border padding-h4 color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h1">156</p>
            <p>inscriptions</p>
          </li>
          <li
            class="stat box no-border padding-h4 color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h1">642</p>
            <p>visiteurs uniques</p>
          </li>
          <li
            class="stat box no-border padding-h4 color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h1">7734</p>
            <p>pages vues</p>
          </li>
        </ul>
      </section>

      <!-- Partenaires éditeurs -->
      <section class="stack gap-down-h4">
        <h2>Partenaires</h2>

        <div class="partners-grid">
          {/* On boucle sur le tableau des images */}
          {
            imagesPartners.map(({ optimizedMeta, alt, finalLink }) => {
              const imgTag = <img src={optimizedMeta.src} {...optimizedMeta.attributes} alt={alt} />
              return finalLink ? (
                <a href={finalLink} target={finalLink.startsWith('http') ? '_blank' : ''}>
                  {imgTag}
                </a>
              ) : (
                imgTag
              )
            })
          }
        </div>
      </section>

      <!-- App compagnon (tilted card) -->
      <section class="app-card box no-border padding-h4 flow border-radius-s">
        <h3 class="color-secondary">Une app compagnon</h3>
        <p>Une autre manière de découvrir le festival depuis ton smartphone ou ton PC.</p>
        <div>
          <a href="#" class="cta-button padding-x-relative-l border-radius-m">C'est par ici</a>
        </div>

        <!-- App mini-stats -->
        <div
          class="flow horizontal justify-content-space-around padding-y-relative-s app-stats-border"
        >
          <div class="flow center text">
            <p class="size-h2 stat-nb-secondary">1300</p>
            <p>visiteurs uniques</p>
          </div>
          <div class="flow center text">
            <p class="size-h2 stat-nb-secondary">27735</p>
            <p>pages vues</p>
          </div>
        </div>
      </section>

      <!-- Galerie Photos -->
      <section class="flow">
        <h2>Galerie Photos</h2>
        <GalleryFull {images} columns={5} />
      </section>
    </main>
  </BasicPage>
</SkeletonPage>

<style>
  /* Tilted app card */
  .app-card {
    transform: rotate(1.5deg);
    margin: var(--size-h3) auto;
    width: 90%;
    max-width: 500px;
    box-shadow: var(--shadow-raised-s);
    border: 1px solid hsl(0, 0%, 90%);
  }

  /* CTA button */
  .cta-button {
    display: inline-block;
    background: var(--color-primary);
    color: var(--color-neutral);
    padding: 10px 20px;
    text-decoration: none;
    font-weight: bold;
  }

  /* App stats top border separator */
  .app-stats-border {
    border-top: 1px solid hsl(0, 0%, 90%);
  }

  /* Gallery images */
  .gallery-img {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }

  .partners-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: var(--size-h2);
    align-items: center;
    justify-items: center;
    margin-bottom: var(--size-h2);
  }
  .partners-grid img {
    max-width: 100%;
    height: auto;
    object-fit: contain;
    max-height: 100px;
  }
  @media (min-width: 1024px) {
    .partners-grid {
      grid-template-columns: repeat(8, 1fr);
    }
  }

  section {
    padding-block: var(--size-h1);
  }

  div.flow > * {
    --flow-space: var(--gap-h2);
  }

  .stat {
    padding-block: var(--size-h1);
  }

  .video-container {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .video-container iframe {
    width: 66.66%;
    aspect-ratio: 16 / 9;
    border-radius: var(--border-radius-l);
  }
</style>
