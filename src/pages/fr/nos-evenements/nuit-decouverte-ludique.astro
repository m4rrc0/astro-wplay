  },
  {
    fileName: 'logo-g-a-g',
    alt: 'Logo de Geek Attitude Games',
    link: '',
  },
  {
    fileName: 'logo-gigamic',
    alt: 'Logo de Gigamic',
    link: '',
  },
  {
    fileName: 'logo-iello',
    alt: 'Logo de Iello',
    link: '',
  },
  {
    fileName: 'logo-jeux-opla',
    alt: 'Logo de Jeux Opla',
    link: '',
  },
  {
    fileName: 'logo-jumping-turtles',
    alt: 'Logo de Jumping Turtle Games',
    link: '',
  },
  {
    fileName: 'logo-la-haute-roche',
    alt: 'Logo de La Haute Roche',
    link: '',
  },
  {
    fileName: 'logo-libellud',
    alt: 'Logo de Libellud',
    link: 'https://www.libellud.com',
  },
  {
    fileName: 'logo-lui-meme',
    alt: 'Logo de Lui-même',
    link: 'https://luimeme.com',
  },
  {
    fileName: 'logo-matagot',
    alt: 'Logo de Matagot',
    link: 'https://www.matagot.com',
  },
  {
    fileName: 'logo-origames',
    alt: "Logo d'Origames",
    link: 'https://www.origames.fr',
  },
  {
    fileName: 'logo-renegade',
    alt: 'Logo de Renegade',
    link: 'https://www.renegade-france.fr',
  },
  {
