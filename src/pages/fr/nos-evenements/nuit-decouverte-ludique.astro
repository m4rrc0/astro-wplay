---
import { SkeletonPage, BasicPage } from '@layouts'
import { SEO } from '@components'
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import bannerPaper from '../../../assets/images/WannaPlay-banner-paper.jpeg'
import { getOrganizations } from '../../../store/dataService.js'
import getOptimizedImages from '../../../utils/getOptimizedImages.js'
import GalleryFull from '@partials/GalleryFull.astro'

const lang = { code: 'fr' }

const partnersData = [
  {
    fileName: 'logo-act-in-games',
    alt: 'Logo de Act in games',
    link: '',
  },
  {
    fileName: 'logo-ankama',
    alt: 'Logo de Ankama',
    link: 'https://www.ankama.com/fr',
  },
  {
    fileName: 'logo-art-of-games',
    alt: 'Logo de Art of Games',
    link: '',
  },
  {
    fileName: 'logo-asmo',
    alt: 'Logo de Asmodee',
    link: '',
  },
  {
    fileName: 'logo-cocktail-games',
    alt: 'Logo de Cocktail Games',
    link: 'https://www.cocktailgames.com',
  },
  {
    fileName: 'logo-discovery-game',
    alt: 'Logo de Discovery game',
    link: 'https://www.discovery-game.com',
  },
  {
    fileName: 'logo-dragon-dawn-production',
    alt: 'Logo de Dragon Dawn Productions',
    link: 'https://www.ddpgames.com',
  },
  {
    fileName: 'logo-dtda',
    alt: 'Logo de DTDA',
    link: 'https://www.dtda.fr/fr/',
  },
  {
    fileName: 'logo-exod-games',
    alt: 'Logo de Exod Games',
    link: '',
  },
  {
    fileName: 'logo-explor8',
    alt: 'Logo de Explor8',
    link: '',
  },
  {
    fileName: 'logo-flatlined-games',
    alt: 'Logo de Flatlined Games',
    link: 'https://www.flatlinedgames.com',
  },
  {
    fileName: 'logo-game-brewer',
    alt: 'Logo de Game Brewer',
