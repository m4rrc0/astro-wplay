---
import { SkeletonPage, BasicPage } from '@layouts'
import { SEO } from '@components'

import bannerPaper from '../../../assets/images/WannaPlay-banner-paper.jpeg'

const lang = { code: 'fr' }
---

<SkeletonPage {lang}>
  <SEO
    slot="head"
    ogType="website"
    title="Tables ouvertes - BGF 2017"
    description="Retour sur l'initiative des tables ouvertes lors du Brussels Games Festival 2017."
    socialImage={'https://www.placeholderimage.eu/1200x630'}
    ogVideo={false}
    twitterCard="summary"
  />

  <BasicPage {lang}>
    <main class="center max stack gap-down-h3" style="margin-top: 0;">
      <!-- Header -->
      <header
        class="center text flow items-center color-palette-trans background-overlay padding-y-relative-xl"
        style='background-image: url("/assets/images/WannaPlay-banner-paper.jpeg");'
      >
        <h1>
          Brussels Games Festival 2017<br />
          Tables ouvertes
        </h1>
      </header>

      <!-- Intro -->
      <section class="flow padding-x-relative-l">
        <p class="size-h4">
          Une semaine d'effervescence ludique pour connecter les joueurs autour des tables du
          festival.
        </p>
      </section>

      <!-- Le concept (Tilted box) -->
      <section
        class="sur-place-box padding-relative-l flow border-radius-s"
        data-c-p="teal"
        data-c-p-var="funky"
      >
        <h3>Le concept</h3>
        <p>
          Les "Tables ouvertes" permettent aux festivaliers de se regrouper, de découvrir des
          nouveautés et de partager leur passion du jeu dans une ambiance conviviale et inclusive.
        </p>
      </section>

      <!-- Video -->
      <section class="flow">
        <h2>Revivez l'événement</h2>
        <div class="video-container">
          <iframe
            src="https://www.youtube.com/embed/ObbUL0Oosaw"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          >
          </iframe>
        </div>
      </section>

      <!-- Stats -->
      <section>
        <ul class="reset grid-fluid" style="--width-column-min: var(--width-col-8);">
          <li
            class="stat box no-border padding-p color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h2">5099</p>
            <p>pages vues</p>
          </li>
          <li
            class="stat box no-border padding-p color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h2">480</p>
            <p>visiteurs uniques</p>
          </li>
          <li
            class="stat box no-border padding-p color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h2">71</p>
            <p>inscriptions</p>
          </li>
        </ul>
      </section>
    </main>
  </BasicPage>
</SkeletonPage>

<style>
  .video-container {
    width: 100%;
  }

  .video-container iframe {
    width: 66.66%;
    aspect-ratio: 16 / 9;
    border-radius: var(--border-radius-l);
  }

  /* Concept Box (Tilted style) */
  .sur-place-box {
    transform: rotate(-1deg);
    margin: var(--size-h4) auto;
    max-width: 700px;
    box-shadow: var(--shadow-raised-s);
  }

  section {
    padding-block: var(--size-h2);
  }

  div.flow > * {
    --flow-space: var(--gap-h3);
  }

  .stat {
    padding-block: var(--size-h2);
  }

  .video-container {
    width: 100%;
    display: flex;
    justify-content: center;
  }
</style>
