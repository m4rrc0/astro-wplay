---
import { SkeletonPage, BasicPage } from '@layouts'
import { SEO } from '@components'

import bannerPaper from '../../../assets/images/WannaPlay-banner-paper.jpeg'

const lang = { code: 'fr' }
---

<SkeletonPage {lang}>
  <SEO
    slot="head"
    ogType="website"
    title="Tables ouvertes - BGF 2017"
    description="Retour sur l'initiative des tables ouvertes lors du Brussels Games Festival 2017."
    socialImage={'https://www.placeholderimage.eu/1200x630'}
    ogVideo={false}
    twitterCard="summary"
  />

  <BasicPage {lang}>
    <main class="center max stack gap-down-h3" style="margin-top: 0;">
      <!-- Header -->
      <header
        class="center text flow items-center color-palette-trans background-overlay padding-y-relative-xl"
        style='background-image: url("/assets/images/WannaPlay-banner-paper.jpeg");'
      >
        <h1>
          Brussels Games Festival 2017<br />
          Tables ouvertes
        </h1>
      </header>

      <!-- Intro -->
      <section class="flow padding-x-relative-l">
        <p>
          Premier test grandeur nature en août 2017, on participe pour la première fois au
          <a href="https://brusselsgamesfestival.be/fr/">Brussels Games Festival</a>. Le projet en
          est encore à ses débuts et l’objectif est clair: tester le concept en situation réelle
        </p>
        <p>
          L’idée repose sur l'inscription via notre site à des tables ouvertes proposées par des
          joueurs sur place, où les festivaliers peuvent se regrouper librement, découvrir des
          nouveautés et partager leur passion du jeu dans une ambiance conviviale.
        </p>
        <p>
          Lors de la nocturne, un système de réservation est également mis en place pour faciliter
          l’accès aux parties et encourager les rencontres entre joueurs.
        </p>
        <p>
          Peu à peu, les tables se remplissent. Les participants s’installent, découvrent le
          fonctionnement et les premières parties démarrent. Les échanges se multiplient, les
          rencontres se créent, tandis que l'on observe attentivement les réactions.
        </p>
        <p>
          Même si le succès reste mitigé, les retours sont encourageants. Cette première
          expérimentation permet de mieux comprendre les attentes des joueurs et d’affiner le
          projet.
        </p>
        <p>
          Une étape importante dans l’évolution du projet: le passage de l’idée à l’expérimentation
          sur le terrain.
        </p>
      </section>

      <!-- Video -->
      <section class="flow">
        <div class="video-container">
          <iframe
            src="https://www.youtube.com/embed/ObbUL0Oosaw"
            title="YouTube video player"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          >
          </iframe>
        </div>
      </section>

      <!-- Stats -->
      <section>
        <ul class="reset grid-fluid" style="--width-column-min: var(--width-col-8);">
          <li
            class="stat box no-border padding-h4 color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h1">5099</p>
            <p>pages vues</p>
          </li>
          <li
            class="stat box no-border padding-h4 color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h1">480</p>
            <p>visiteurs uniques</p>
          </li>
          <li
            class="stat box no-border padding-h4 color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h1">71</p>
            <p>inscriptions</p>
          </li>
        </ul>
      </section>
    </main>
  </BasicPage>
</SkeletonPage>

<style>
  .video-container {
    width: 100%;
  }

  .video-container iframe {
    width: 66.66%;
    aspect-ratio: 16 / 9;
    border-radius: var(--border-radius-l);
  }

  /* Concept Box (Tilted style) */
  .sur-place-box {
    transform: rotate(-1deg);
    margin: var(--size-h3) auto;
    max-width: 700px;
    box-shadow: var(--shadow-raised-s);
  }

  section {
    padding-block: var(--size-h1);
  }

  div.flow > * {
    --flow-space: var(--gap-h2);
  }

  .stat {
    padding-block: var(--size-h1);
  }

  .video-container {
    width: 100%;
    display: flex;
    justify-content: center;
  }
</style>
