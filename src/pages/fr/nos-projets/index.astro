---
import { SkeletonPage, BasicPage } from '@layouts'
import { SEO } from '@components'
import coverPaper from '@assets/images/WannaPlay-banner-paper.jpeg'
import coverFestival2023 from '@assets/images/our-projects/Festival-2023-2.webp'
import coverFestival2022 from '@assets/images/our-projects/Festival-2022.webp'
import coverInauguration from '@assets/images/our-projects/Inauguration-1.webp'
import coverFestivalBiere from '@assets/images/our-projects/Festival-de-la-Biere.jpeg'
import coverIdeesBleues from '@assets/images/our-projects/festival-idees-bleues.webp'
import coverBELvue from '@assets/images/our-projects/BELvue.webp'
import coverMuntpunt from '@assets/images/our-projects/Muntpunt-3.webp'
import coverJeuxJardin from '@assets/images/our-projects/soiree-theme-jardin-3.webp'
import coverFonderie from '@assets/images/our-projects/la-Fonderie-3.webp'
import coverJeuParfait from '@assets/images/our-projects/BGF-2020-Le-jeu-parfait.webp'
import coverNuitDecouvertes from '@assets/images/our-projects/nuit-decouvertes-ludiques.webp'
import coverAppCompagnon from '@assets/images/our-projects/BGF-2019-app-compagnon.webp'
import coverTablesOuvertes from '@assets/images/our-projects/BGF-2017-tables-ouvertes.webp'
import coverHachette from '@assets/images/our-projects/avec-Hachette.webp'
import coverJeuTAime from '@assets/images/our-projects/jeux-taime-1.webp'

const lang = { code: 'fr' }
const pageUrl = new URL(Astro.url.pathname, Astro.site)
const canonicalUrl = (pageUrl.href + '/').replace(/[\/]+$/, '/')
---

<SkeletonPage {lang}>
  <SEO
    slot="head"
    ogType="website"
    title="Nos événements"
    description="Découvrez les événements passés et à venir de Wanna Play in Brussels"
    {canonicalUrl}
    socialImage={'/assets/images/LOGO-1024px.png'}
    ogVideo={false}
    twitterCard="summary"
  />
  <BasicPage {lang}>
    <main class="center width-max flow gap-h2">
      <header
        class="flex center text flow items-center gap-h7 color-palette-trans background-overlay padding-y-relative-xl full-bleed"
        style='background-image: url("/assets/images/WannaPlay-banner-paper.jpeg"); box-sizing: border-box; --full-bleed-max-width: var(--width-max);'
      >
        <h1>Nos projets</h1>
      </header>

      <div class="flow">
        <h2 class="center text">
          Depuis 2017, Wanna Play réunit les joueurs autour de concepts très différents
        </h2>
        <p>
          Depuis nos débuts, on adore créer des moments qui rassemblent. On a déjà organisé deux
          festivals, de nombreuses soirées jeux et animations publiques ou privées, ainsi que des
          activités intergénérationnelles où tout le monde trouve sa place. On propose aussi des
          animations pour des publics à besoins spécifiques, des formations et ateliers pour les
          professionnels, des team buildings d’entreprise et des animations commerciales en magasin.
        </p>

        <p>
          Grâce à notre réseau de partenaires et d’animateurs, nous pouvons également imaginer des
          événements sur mesure, adaptés à tes envies et à ton public. D’une après-midi ou soirée
          jeux conviviale à la création de nouveaux concepts utilisant le jeu d’une autre manière,
          on s’adapte à chaque demande et à chaque contexte.
        </p>

        <p>
          Bref, on aime varier les formats, tester de nouvelles idées et créer des expériences qui
          ont du sens. Et ce n’est que le début… Retrouve ici quelques exemples de projets passés et
          à venir.
        </p>
      </div>

      <p class="center text p">Retrouve ici quelques exemples de projets passés et à venir</p>

      <section class="flow">
        <h2 class="center text">Organisés par Wanna Play</h2>
        <ul
          class="grid-fluid gap-p list reset projects-list-wanna-play"
          style="--columns: 3; --width-column-min: var(--width-col-4);"
        >
          <li class="project-card border-radius-m color-palette-variation-contrast">
            <div
              class="project-card-header"
              style={`background-image: url('${coverFestival2023.src}');`}
            >
              <p class="bold">08.07.2023</p>
            </div>
            <div class="project-card-body box no-border flow">
              <h3 class="h4">Festival Wanna Play in Brussel 2023</h3>
              <p>Bruxelles - Jardin du Grand Hospice Pacheco</p>
              <a href="/fr/nos-projets/wanna-play-in-brussel-2023">En savoir plus</a>
            </div>
          </li>
          <li class="project-card border-radius-m color-palette-variation-contrast">
            <div
              class="project-card-header"
              style={`background-image: url('${coverFestival2022.src}');`}
