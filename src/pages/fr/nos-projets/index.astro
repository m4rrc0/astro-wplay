<style>
  .project-card {
    transition: all 0.3s ease;
    isolation: isolate;
  }

  .project-card:hover .project-card-header::after {
    opacity: 0.2;
  }
  .project-card:hover .project-card-header p {
    background-color: transparent;
    background-size: 100% 100%;
  }

  .project-card-header {
    width: 100%;
    height: 15rem;
    display: flex;
    align-items: flex-end;
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: hidden;
    backdrop-filter: grayscale(1);

    & p {
      display: block;
      width: 100%;
      padding-inline: var(--size-p);
      padding-block: 0.5em;
      position: relative;
      z-index: 3;
      background-image: linear-gradient(var(--color-bg), var(--color-bg));
      background-repeat: no-repeat;
      background-size: 100% 0%;
      background-position: bottom;

      transition:
        background-size 0.3s ease-out,
        color 0.3s;
    }
  }

  .project-card-header::after {
    content: '';
    position: absolute;
    inset: 0;
    mix-blend-mode: lighten;
    background-color: var(--color-secondary);

    opacity: 0.9;
    transition: opacity 0.3s ease;
    z-index: 1;
  }
  .project-card-header::before {
    content: '';
    position: absolute;
    inset: 0;
    mix-blend-mode: darken;
    background-color: var(--color-bg);

    opacity: 1;
    transition: opacity 0.3s ease;
    z-index: 1;
  }

  .project-card:hover .project-card-header::before,
  .project-card:hover .project-card-header::after {
    opacity: 0;
  }

  .project-card-body a.button {
    width: fit-content;
    text-align: center;
    padding-inline: var(--size-p);
    text-decoration: none;
  }

  .projects-list-wanna-play .project-card-header::after {
    background-color: var(--color-bg);
  }
  .projects-list-wanna-play .project-card-header::before {
    background-color: var(--color-secondary);
  }
</style>
