---
import { SkeletonPage, BasicPage } from '@layouts'
import '@styles/partials/our-projets.css'
import { SEO, Img } from '@components'
import { Image } from 'astro:assets'
import { YouTube } from 'astro-embed'
import { getOrganizations } from '../../../store/dataService.js'
import getOptimizedImages from '../../../utils/getOptimizedImages.js'
import GalleryFull from '@partials/GalleryFull.astro'
import affiche from '@assets/images/festival-2023/visibilite/festival-2023-affiche.webp'
import imgEntree from '@assets/images/festival-2023/visibilite/festival-2023-entree.webp'
import imgMap from '@assets/images/festival-2023/visibilite/festival-2023-map.webp'
import imgPanneaux from '@assets/images/festival-2023/visibilite/festival-2023-panneaux.webp'
import imgSignaletique from '@assets/images/festival-2023/visibilite/festival-2023-signaletique.webp'
import imgVideo from '@assets/images/festival-2023/visibilite/festival-2023-video.webp'
import imgVideoJo from '@assets/images/festival-2023/visibilite/festival-2023-video-jo.webp'
import imgVideoJo2 from '@assets/images/festival-2023/visibilite/festival-2023-video-jo-2.webp'
import imgVideoMarc from '@assets/images/festival-2023/visibilite/festival-2023-video-marc.webp'
import imgVideoMarc2 from '@assets/images/festival-2023/visibilite/festival-2023-video-marc-2.webp'
import imgVideoTess from '@assets/images/festival-2023/visibilite/festival-2023-video-tess.webp'
import tatianaDronjak from '@assets/images/partners/tatiana-dronjak.webp'

const mainPartnersData = [
  {
    fileName: 'logo-grand-hospice',
    alt: 'Logo Grand Hospice',
    link: 'https://www.grand-hospice.brussels/',
  },
  {
    fileName: 'logo-jardin-noir',
    alt: 'Logo Jardin Noir',
    link: 'https://www.grand-hospice.brussels/jardin/',
  },
  {
    fileName: 'logo-francophones-bruxelles',
    alt: 'Logo Francophones Bruxelles',
    link: 'https://ccf.brussels/',
  },
]

// Conference partners
const conferenceData = [
  {
    fileName: 'thierry-et-amaya',
    name: 'Thierry Saeys',
    role: 'SAJOU',
    alt: 'Portrait de Thierry Saeys',
    link: 'https://www.sajou.be/',
  },
  {
    fileName: 'theo-riviere',
    name: 'Théo Rivière',
    role: 'Auteur',
    alt: 'Portrait de Théo Rivière',
    link: 'https://www.instagram.com/theo_sacha/',
  },
  {
    fileName: 'gioia-et-anthony',
    name: 'Gioia & Anthony',
    role: 'Njoy Games',
    alt: 'Portrait de Gioia & Anthony',
    link: 'https://www.facebook.com/Njoygamestaverne/',
  },
  {
    fileName: 'michel-van-langendonckt',
    name: 'Michel Van Langendonckt',
    role: 'Ludo asbl',
    alt: 'Portrait de Michel Van Langendonckt',
    link: 'https://ludobel.be/',
  },
  {
    fileName: 'geraldine-volders',
    name: 'Géraldine Volders',
    role: 'Repos Production',
    alt: 'Portrait de Géraldine Volders',
    link: '',
  },
  // {
  //   fileName: 'tatiana-dronjak',
  //   name: 'Tatiana Dronjak',
  //   role: 'Girl dot Game',
  //   alt: 'Portrait de Tatiana Dronjak',
  //   link: 'https://www.youtube.com/channel/UCUU0uDuttbZAs-n334cYrhQ',
  // },
]

// VIP partners
const vipData = [
  { fileName: 'logo-art-of-games', alt: 'Logo Art of Games', link: '' },
  { fileName: 'logo-ludeo', alt: 'Logo Ludeo', link: '' },
  { fileName: 'logo-happy-meeple', alt: 'Logo Happy Meeple', link: '' },
  { fileName: 'logo-critical-', alt: 'Logo Critical', link: '' },
  {
    fileName: 'logo-hachette-boardgames-benelux',
    alt: 'Logo Hachette Boardgames Benelux',
    link: '',
  },
  { fileName: 'logo-explor8', alt: 'Logo Explor8', link: '' },
  { fileName: 'logo-asmo', alt: 'Logo Asmodee', link: '' },
  { fileName: 'logo-byr', alt: 'Logo BYR', link: '' },
  { fileName: 'logo-ludotrotter-ixelles', alt: 'Logo Ludotrotter Ixelles', link: '' },
]

// General partners
const generalData = [
  { fileName: 'logo-sajou', alt: 'Logo Sajou', link: '' },
  { fileName: 'logo-kaedama', alt: 'Logo Kaedama', link: '' },
  { fileName: 'logo-njoy-games', alt: 'Logo Njoy Games', link: '' },
  { fileName: 'logo-ludobel-asbl', alt: 'Logo Ludobel asbl', link: '' },
  { fileName: 'logo-repos-production', alt: 'Logo Repos Production', link: '' },
  { fileName: 'logo-girl-dot-game', alt: 'Logo Girl dot Game', link: '' },
  { fileName: 'logo-schmeta', alt: 'Logo Schmeta', link: '' },
  { fileName: 'logo-iello', alt: 'Logo Iello', link: '' },
  { fileName: 'logo-mind-cycling', alt: 'Logo Mind Cycling', link: '' },
  { fileName: 'logo-sit-down', alt: 'Logo Sit Down', link: '' },
  { fileName: 'logo-univers-de-thot', alt: 'Logo Univers de Thot', link: '' },
  { fileName: 'logo-wana-game', alt: 'Logo Wana Game', link: '' },
  { fileName: 'logo-foxtroll-games', alt: 'Logo Foxtroll Games', link: '' },
  { fileName: 'logo-ploef', alt: 'Logo Ploef', link: '' },
  { fileName: 'logo-auberjeux', alt: 'Logo Auberjeux', link: '' },
  { fileName: 'logo-ludiris-asbl', alt: 'Logo Ludiris asbl', link: '' },
  { fileName: 'logo-sdc', alt: 'Logo SDC', link: '' },
  { fileName: 'logo-le-game-au-vert', alt: 'Logo Le Game au Vert', link: '' },
  { fileName: 'logo-ludenne', alt: 'Logo Ludenne', link: '' },
  { fileName: 'logo-ludo-ludo', alt: 'Logo Ludo Ludo', link: '' },
  { fileName: 'quentin-lammerant', alt: 'Quentin Lammerant', link: '' },
  { fileName: 'logo-des-mentiel', alt: 'Logo Des Mentiel', link: '' },
  { fileName: 'logo-au-fil-des-mot', alt: 'Logo Au Fil des Mots', link: '' },
  { fileName: 'logo-yapaka', alt: 'Logo Yapaka', link: '' },
  { fileName: 'logo-alpa-ludismes', alt: 'Logo Alpa Ludismes', link: '' },
  { fileName: 'logo-des-jeux-une-fois', alt: 'Logo Des Jeux Une Fois', link: '' },
]

const allSlugs = [...mainPartnersData, ...conferenceData, ...vipData, ...generalData].map(p =>
  p.fileName.replace(/^logo-/, '')
)

const organizations = await getOrganizations({
  filter: {
    _and: [{ status: { _in: ['published', 'to_check'] } }, { slug: { _in: allSlugs } }],
  },
})

const partners = import.meta.glob<{ default: ImageMetadata }>(
  '@assets/images/partners/*.{jpeg,jpg,png,gif,webp,svg}'
)

const imagesMainPartners = await getOptimizedImages(mainPartnersData, partners, organizations)
const imagesConferencePartners = await getOptimizedImages(conferenceData, partners, organizations)
const imagesVipPartners = await getOptimizedImages(vipData, partners, organizations)
const imagesGeneralPartners = await getOptimizedImages(generalData, partners, organizations)

// const { lang } = Astro.props
const lang = { code: 'fr' }

const imagesOriane = import.meta.glob<{ default: ImageMetadata }>(
  '@assets/images/festival-2023/oriane-delavallee/*.{jpeg,jpg,png,gif,webp,svg}'
)
const imagesPaulo = import.meta.glob<{ default: ImageMetadata }>(
  '@assets/images/festival-2023/paulo-ribeiro/*.{jpeg,jpg,png,gif,webp,svg}'
)
const imagesSylwia = import.meta.glob<{ default: ImageMetadata }>(
  '@assets/images/festival-2023/sylwia-malachowska/*.{jpeg,jpg,png,gif,webp,svg}'
)
const imagesBudgets = import.meta.glob<{ default: ImageMetadata }>(
  '@assets/images/festival-2023/budgets/*.{jpeg,jpg,png,gif,webp,svg}'
)
const imagesSurprises = import.meta.glob<{ default: ImageMetadata }>(
  '@assets/images/festival-2023/surprises/*.{jpeg,jpg,png,gif,webp,svg}'
)
---

<SkeletonPage {lang}>
  <SEO
    slot="head"
    ogType="website"
    title="Wanna Play in Brussel 2023"
    description="Un festival gratuit d’une journée consacré aux jeux de société"
    socialImage={'/assets/images/LOGO-1024px.png'}
    ogVideo={false}
    twitterCard="summary"
  />
  <BasicPage {lang}>
    <main class="center width-max" style="min-width: 0;">
      <header
        class="flex center text flow items-center color-palette-trans background-overlay padding-y-relative-xl full-bleed"
        style='background-image: url("/assets/images/WannaPlay-banner-paper.jpeg"); box-sizing: border-box; --full-bleed-max-width: var(--width-max);'
      >
        <h1>Wanna Play in Brussel 2023</h1>
      </header>

      <section class="flow">
        <div class="flow">
          <p class="h2">2e édition</p>
          <p>
            Le festival «Wanna Play in Brussels» a connu sa deuxième édition cette année. Après le
            succès fulgurant de la première édition. Cet événement ludique a été une véritable
            surprise dans le monde du jeu de société en Belgique, et nous avons décidé de redoubler
            d’efforts pour offrir une expérience encore plus incroyable cette année-ci.
          </p>
          <p>
            Le festival s’est déroulé le samedi 08.07.2023 au Jardin du Grand Hospice Pacheco dans
            le centre de Bruxelles, cette année avec le soutien de la COCOF et autres partenaires.
            L’événement était gratuit pour les visiteurs et visait un public adulte varié, ainsi que
            les familles avec enfants.
          </p>
        </div>
        <div class="flow">
          <p class="h3">Le festival avait plusieurs objectifs principaux</p>
          <ol class="flow">
            <li>
              <p><strong>Faire découvrir les jeux de société modernes</strong></p>
              <p>
                Nous avons souhaité offrir aux participants l’opportunité de découvrir et d’explorer
                les jeux de société contemporains, en mettant en avant des créateurs, auteurs,
                éditeurs et distributeurs de jeux.
              </p>
            </li>
            <li>
              <p><strong>Présence des acteurs ludiques belges</strong></p>
              <p>
                Une grande diversité d’acteurs ludiques belges étaient présents, tels que des
                associations, des clubs, des éditeurs, des distributeurs, des créateurs de contenu,
                une école et des ludothèques. Le festival permet de favoriser les échanges et les
                rencontres.
              </p>
            </li>
            <li>
              <p><strong>Ateliers, conférences et animations</strong></p>
              <p>
                Le programme était varié comprenant des activités pour les familles et le grand
                public tout au long de la journée. Nous avions également des activités plus ciblées
                pour les curieux ou les joueurs plus avertis, tels que des conférences inspirantes,
                des ateliers de découverte sur différents sujets, des sessions de speed-gaming pour
                favoriser les rencontres, ainsi qu’un tournois et des initiations.
              </p>
            </li>
          </ol>
        </div>
        <div class="cluster padding-x-relative-xl justify-center gap-h1">
          {/* On boucle sur le tableau des PARTENAIRES PRINCIPAUX */}
          {
            imagesMainPartners.map(({ optimizedMeta, alt, finalLink }) => {
              const imgTag = (
                <Image
                  src={optimizedMeta.src}
                  {...optimizedMeta.attributes}
                  alt={alt}
                  width="150px"
                />
              )
              return finalLink ? (
                <a
                  href={finalLink}
                  target={finalLink.startsWith('http') ? '_blank' : ''}
                  class="content-center flow justify-center"
                >
                  {imgTag}
                </a>
              ) : (
                imgTag
              )
            })
          }
        </div>
        <div
          class="video-container grid-fluid"
          style="--column-width-min: 100%; max-width: var(--width-col-2); margin-inline: auto;"
        >
          <YouTube id="cc5frcsJbcc" title="Wanna Play in Brussel 2023" />
        </div>
      </section>
      <section class="flow">
        <div class="carousel" role="region" aria-roledescription="carousel">
          <ul class="carousel-inner reset reel overflowing">
            <li class="carousel-item box border-radius-l" role="group" aria-roledescription="slide">
              <figure class="flow">
                <blockquote>
                  <p>
                    "Toute l’organisation me semblait au top, et l’endroit choisi pour la bourse aux
                    jeux était une bonne idée. Des bénévoles et un transpalette ont beaucoup aidé à
                    ce que tout se passe sans problème."
                  </p>
                </blockquote>
                <figcaption class="bold">
                  — Benjamin, <cite>Vendeur bourse aux jeux</cite>
                </figcaption>
              </figure>
            </li>

            <li class="carousel-item box border-radius-l" role="group" aria-roledescription="slide">
              <figure class="flow">
                <blockquote>
                  <p>
                    "Chouette festival qui permet de découvrir ou redécouvrir le monde ludique, de
                    belles personnes et plein de nouveaux jeux. À refaire!"
                  </p>
                </blockquote>
                <figcaption class="bold">
                  — Céleste, <cite>Visiteur</cite>
                </figcaption>
              </figure>
            </li>

            <li class="carousel-item box border-radius-l" role="group" aria-roledescription="slide">
              <figure class="flow">
                <blockquote>
                  <p>
                    “Un évènement immanquable, beaucoup de choix de jeux et d’activités pour tous
                    les âges, dans un lieu très agréable.”
                  </p>
                </blockquote>
                <figcaption class="bold">
                  — Ooki, <cite>Visiteur</cite>
                </figcaption>
              </figure>
            </li>

            <li class="carousel-item box border-radius-l" role="group" aria-roledescription="slide">
              <figure class="flow">
                <blockquote>
                  <p>"Un chouette petit festival très convivial dans un endroit magique."</p>
                </blockquote>
                <figcaption class="bold">
                  — Le meeple à lunettes, <cite>Visiteur</cite>
                </figcaption>
              </figure>
            </li>

            <li class="carousel-item box border-radius-l" role="group" aria-roledescription="slide">
              <figure class="flow">
                <blockquote>
                  <p>
                    “Super événement! L’occasion de découvrir et tester plein de nouveaux jeux dans
                    une ambiance relax et conviviale.”
                  </p>
                </blockquote>
                <figcaption class="bold">
                  — U1, <cite>Visiteur</cite>
                </figcaption>
              </figure>
            </li>

            <li class="carousel-item box border-radius-l" role="group" aria-roledescription="slide">
              <figure class="flow">
                <blockquote>
                  <p>
                    “Conférences pertinentes, atelier peinture et jeu de rôle qui donnent envie, et
                    des jeux bien sûr.”
                  </p>
                </blockquote>
                <figcaption class="bold">
                  — Lilouch, <cite>Visiteur</cite>
                </figcaption>
              </figure>
            </li>
          </ul>
        </div>

        <ul class="reset grid-fluid gap-p" style="--width-column-min: var(--width-col-8);">
          <li
            class="stat box no-border padding-p color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h2">2000</p>
            <p>participants</p>
          </li>
          <li
            class="stat box no-border padding-p color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h2">200</p>
            <p>jeux différents</p>
          </li>
          <li
            class="stat box no-border padding-p color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h2">+100</p>
            <p>tables de jeux</p>
          </li>
          <li
            class="stat box no-border padding-p color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h2">+74</p>
            <p>animateurs</p>
          </li>
          <li
            class="stat box no-border padding-p color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h2">41</p>
            <p>partenaires</p>
          </li>
          <li
            class="stat box no-border padding-p color-palette-trans background-overlay border-radius-s text-center"
          >
            <p class="h2">33</p>
            <p>bénévoles</p>
          </li>
        </ul>
      </section>

      <section class="flow">
        <h2>Activités</h2>
        <ul class="flow">
          <li>
            <p>Tables de jeux</p>
            <p>
              Des espaces étaient dédiés aux jeux de société où les visiteurs pouvaient jouer et
              découvrir de nouveaux titres, chaque table était tenue par un partenaire ou un
              bénévole, afin d’y animer les parties tout en expliquant les règles des jeux.
            </p>
          </li>
          <li>
            <p>Initiation au jeu de rôle (RPG)</p>
            <p>
              Une occasion pour les visiteurs (adultes et enfants) de s’immerger dans l’univers du
              jeu de rôle.
            </p>
          </li>
          <li>
            <p>Initiation à la peinture de figurines et aux jeux associés</p>
            <p>
              Des ateliers étaient proposés aux visiteurs (adultes et enfants) pour apprendre les
              techniques de peinture de figurines utilisées dans certains jeux.
            </p>
          </li>
          <li>
            <p>Zone enfants</p>
            <p>
              Un espace dédié aux plus jeunes avec des tables de jeux, du maquillage de tribu et des
              lectures de contes.
            </p>
          </li>
          <li>
            <p>Et plein d'autres</p>
          </li>
        </ul>
      </section>

      <section class="flow">
        <h2>Conférences</h2>
        <div class="flow">
          <h3>Du loisir à la profession: les métiers ludiques d’aujourd’hui et de demain</h3>
          <div class="flow">
            <p>
              Pour cette conférence nous avons rassemblé plusieurs intervenants de renom, tels que:
            </p>
            <!-- <ul>
              <li><strong>Thierry Saeys</strong> (SAJOU)</li>
              <li><strong>Théo Rivière</strong> (Auteur)</li>
              <li><strong>Gioia et Anthony</strong> (Njoy Games)</li>
              <li><strong>Michel Van Langendonckt</strong> (Ludo asbl)</li>
              <li><strong>Géraldine Volders</strong> (Repos Production)</li>
              <li><strong>Tatiana Dronjak</strong> (Girl dot Game)</li>
            </ul> -->
            <!-- Section Conférences -->
            <div class="conference-partners images cluster items-start justify-start">
              {
                imagesConferencePartners.map(
                  ({ optimizedMeta, displayName, role, finalLink, alt }) => {
                    const imgTag = (
                      <Image
                        src={optimizedMeta.src}
                        {...optimizedMeta.attributes}
                        alt={alt}
                        widths={[240, 540, 720, 1200, optimizedMeta.width]}
                        sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1600px) 1200px, ${optimizedMeta.width}px`}
                      />
                    )
                    return (
                      <figure
                        class="flow gap-p"
                        style="text-align: center; align-items: center; margin: 0; width: var(--width-col-8);"
                      >
                        {finalLink ? (
                          <a href={finalLink} target={finalLink.startsWith('http') ? '_blank' : ''}>
                            {imgTag}
                          </a>
                        ) : (
                          imgTag
                        )}
                        <figcaption class="flow gap-p">
                          <strong>{displayName}</strong> {role}
                        </figcaption>
                      </figure>
                    )
                  }
                )
              }
            </div>
          </div>
        </div>
        <div class="flow">
          <h3>La place des femmes dans le monde du jeu</h3>
          <p>
            Cette conférence gratuite et sans inscription, a été animée par Tatiana Dronjak, une
            youtubeuse spécialisée dans les jeux de société (Girl dot Game). Les discussions ont
            porté sur le rôle et la représentation des femmes dans l’univers du jeu, mettant en
            lumière leur contribution et les défis auxquels elles sont confrontées.
          </p>
          <div class="conference-partners images cluster items-start justify-start">
            <figure
              class="flow gap-p"
              style="text-align: center; margin: 0; width: var(--width-col-8);"
            >
              <a href="https://www.youtube.com/channel/UCUU0uDuttbZAs-n334cYrhQ">
                <Image
                  src={tatianaDronjak}
                  alt="Portrait de Tatiana Dronjak"
                  widths={[240, 540, 720, 1200, tatianaDronjak.width]}
                  sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1600px) 1200px, ${tatianaDronjak.width}px`}
                />
              </a>
              <figcaption class="flow gap-p">
                <strong>Tatiana Dronjak</strong> Girl dot Game
              </figcaption>
            </figure>
          </div>
          <p>
            Les participants ont pu découvrir les parcours de ces experts du jeu de société et ont
            reçu des conseils sur les opportunités de carrière dans ce domaine en constante
            évolution.
          </p>
        </div>
      </section>

      <section class="flow">
        <h2>Partenaires</h2>
        <p>
          Nous avons bénéficié du soutien de nombreux partenaires professionnels belges et français,
          ainsi que d’associations bruxelloises. Parmi nos partenaires figuraient des éditeurs, des
          boutiques, des médias spécialisés dans les jeux de société, des ludothèques, une école,
          des influenceurs, des auteurs,…
        </p>
        <p>Leur contribution a été essentielle pour la réussite de l’événement.</p>
        <p>
          Certains n’ont pas pu venir le jour J mais nous ont envoyés des jeux qui ont été animés
          par les bénévoles.
        </p>
        <div class="flow gap-down-p">
          <h3>Partenaires VIP et premium</h3>
          <div class="partners-grid vip">
            {/* On boucle sur le tableau des images */}
            {
              imagesVipPartners.map(({ optimizedMeta, alt, finalLink }) => {
                const imgTag = (
                  <Image
                    src={optimizedMeta.src}
                    {...optimizedMeta.attributes}
                    alt={alt}
                    widths={[240, 540, 720, 1200, optimizedMeta.width]}
                    sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1600px) 1200px, ${optimizedMeta.width}px`}
                  />
                )
                return finalLink ? (
                  <a href={finalLink} target={finalLink.startsWith('http') ? '_blank' : ''}>
                    {imgTag}
                  </a>
                ) : (
                  imgTag
                )
              })
            }
          </div>
          <h3>Autre partenaires</h3>
          <div class="partners-grid">
            {/* On boucle sur le tableau des images */}
            {
              imagesGeneralPartners.map(({ optimizedMeta, alt, finalLink }) => {
                const imgTag = (
                  <Image
                    src={optimizedMeta.src}
                    {...optimizedMeta.attributes}
                    alt={alt}
                    widths={[240, 540, 720, 1200, optimizedMeta.width]}
                    sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1600px) 1200px, ${optimizedMeta.width}px`}
                  />
                )
                return finalLink ? (
                  <a href={finalLink} target={finalLink.startsWith('http') ? '_blank' : ''}>
                    {imgTag}
                  </a>
                ) : (
                  imgTag
                )
              })
            }
          </div>
        </div>
        <div class="carousel" role="region" aria-roledescription="carousel">
          <ul class="carousel-inner reset reel overflowing">
            <li class="carousel-item box border-radius-l" role="group" aria-roledescription="slide">
              <figure class="flow">
